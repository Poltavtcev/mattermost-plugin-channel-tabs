{
    "id": "channel-tabs",
    "name": "Channel Tabs",
    "version": "1.3.5",
    "description": "Add customizable tabs to Mattermost channels — external links, embedded markdown pages, and folders for documentation, rules, and knowledge base.",
    "homepage_url": "https://github.com/mattermost/mattermost-plugin-channel-tabs",
    "support_url": "https://github.com/mattermost/mattermost-plugin-channel-tabs/issues",
    "icon_path": "assets/icon.svg",
    "min_server_version": "7.0.0",
    "server": {
        "executables": {
            "linux-amd64": "server/dist/plugin-linux-amd64",
            "linux-arm64": "server/dist/plugin-linux-arm64",
            "darwin-amd64": "server/dist/plugin-darwin-amd64",
            "darwin-arm64": "server/dist/plugin-darwin-arm64",
            "windows-amd64": "server/dist/plugin-windows-amd64.exe"
        }
    },
    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    },
    "settings_schema": {
        "header": "",
        "footer": "",
        "settings": [
            {
                "key": "MaxTabsPerChannel",
                "display_name": "Maximum Tabs Per Channel",
                "type": "number",
                "default": 30,
                "help_text": "Maximum number of tabs allowed per channel (1-50)."
            },
            {
                "key": "SyncTabsToHeader",
                "display_name": "Duplicate Tabs in Channel (Bot Posts)",
                "type": "bool",
                "default": false,
                "help_text": "When enabled, the plugin creates/updates bot posts in the channel for Page tabs (and the navigation fallback post). Required for the full tabs list in the channel header."
            },
            {
                "key": "HeaderDisplayMode",
                "display_name": "Header Display Mode",
                "type": "radio",
                "default": "none",
                "help_text": "Choose how channel tabs appear in the channel header. Note: Full tabs list requires \"Duplicate Tabs in Channel (Bot Posts)\" to be enabled; otherwise it will behave like hint-only.",
                "options": [
                    {
                        "display_name": "Do not display in header",
                        "value": "none"
                    },
                    {
                        "display_name": "Show tab hint only (single link)",
                        "value": "hint"
                    },
                    {
                        "display_name": "Show full tabs list in header (requires bot posts)",
                        "value": "full"
                    }
                ]
            },
            {
                "key": "HeaderHintLabel",
                "display_name": "Header hint text override",
                "type": "text",
                "default": "",
                "help_text": "Optional custom text for the hint link in channel header (for hint mode). Leave empty to use the default localized label."
            }
        ]
    }
}
